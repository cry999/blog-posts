<mxfile host="app.diagrams.net">
  <diagram name="tail-cycle-count" id="tail-cycle-1">
    <mxGraphModel dx="980" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="860" pageHeight="340" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="しっぽ頂点 p からサイクルへの距離（例: n = 6, p = 1）" style="text;html=1;align=center;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="170" y="12" width="520" height="22" as="geometry" />
        </mxCell>

        <!-- ===== 左: しっぽ＋サイクル。サイクル頂点は E からのサイクル距離でラベル ===== -->
        <mxCell id="tp2" value="p=2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1"><mxGeometry x="53" y="143" width="34" height="34" as="geometry" /></mxCell>
        <mxCell id="tp1" value="p=1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="113" y="143" width="34" height="34" as="geometry" /></mxCell>
        <mxCell id="vE" value="E" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=11;" vertex="1" parent="1"><mxGeometry x="203" y="143" width="34" height="34" as="geometry" /></mxCell>

        <mxCell id="vtl" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="243" y="74" width="34" height="34" as="geometry" /></mxCell>
        <mxCell id="vbl" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="243" y="212" width="34" height="34" as="geometry" /></mxCell>
        <mxCell id="vtr" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="323" y="74" width="34" height="34" as="geometry" /></mxCell>
        <mxCell id="vbr" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="323" y="212" width="34" height="34" as="geometry" /></mxCell>
        <mxCell id="vR" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1"><mxGeometry x="363" y="143" width="34" height="34" as="geometry" /></mxCell>

        <!-- しっぽの辺 -->
        <mxCell id="et" style="endArrow=none;html=1;strokeColor=#999999;" edge="1" parent="1" source="tp2" target="tp1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="et2" style="endArrow=none;html=1;strokeColor=#999999;" edge="1" parent="1" source="tp1" target="vE"><mxGeometry relative="1" as="geometry" /></mxCell>
        <!-- サイクルの辺 -->
        <mxCell id="ce1" style="endArrow=none;html=1;strokeColor=#cccccc;" edge="1" parent="1" source="vE" target="vtl"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce2" style="endArrow=none;html=1;strokeColor=#cccccc;" edge="1" parent="1" source="vtl" target="vtr"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce3" style="endArrow=none;html=1;strokeColor=#cccccc;" edge="1" parent="1" source="vtr" target="vR"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce4" style="endArrow=none;html=1;strokeColor=#cccccc;" edge="1" parent="1" source="vR" target="vbr"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce5" style="endArrow=none;html=1;strokeColor=#cccccc;" edge="1" parent="1" source="vbr" target="vbl"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ce6" style="endArrow=none;html=1;strokeColor=#cccccc;" edge="1" parent="1" source="vbl" target="vE"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="lblLeft" value="数字 = E からのサイクル距離。dist(p, c) = p + (数字)。&#10;同じ距離が両側に 2 つ（緑・青）、対角だけ 1 つ（赤）" style="text;html=1;align=center;fontSize=10;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="30" y="262" width="390" height="40" as="geometry" />
        </mxCell>

        <!-- ===== 右: p=1 の距離ヒストグラム（+2 区間 ＋ 対角 +1） ===== -->
        <mxCell id="rangelbl" value="距離区間 [p+1, p+⌊(n−1)/2⌋] に一律 +2" style="text;html=1;align=center;fontSize=10;fontColor=#3a7d34;" vertex="1" parent="1">
          <mxGeometry x="520" y="58" width="230" height="16" as="geometry" />
        </mxCell>

        <mxCell id="p2lab" value="+2" style="text;html=1;align=center;fontSize=11;fontColor=#3a7d34;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="540" y="120" width="40" height="16" as="geometry" /></mxCell>
        <mxCell id="p3lab" value="+2" style="text;html=1;align=center;fontSize=11;fontColor=#3a7d34;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="610" y="120" width="40" height="16" as="geometry" /></mxCell>
        <mxCell id="p4lab" value="+1" style="text;html=1;align=center;fontSize=11;fontColor=#b85450;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="680" y="160" width="40" height="16" as="geometry" /></mxCell>

        <mxCell id="bar2" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="540" y="140" width="40" height="90" as="geometry" /></mxCell>
        <mxCell id="bar3" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="610" y="140" width="40" height="90" as="geometry" /></mxCell>
        <mxCell id="bar4" value="" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1"><mxGeometry x="680" y="185" width="40" height="45" as="geometry" /></mxCell>

        <mxCell id="axis" style="endArrow=none;html=1;strokeColor=#333333;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="520" y="230" as="sourcePoint" /><mxPoint x="760" y="230" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="x2" value="距離 2" style="text;html=1;align=center;fontSize=10;" vertex="1" parent="1"><mxGeometry x="540" y="232" width="40" height="16" as="geometry" /></mxCell>
        <mxCell id="x3" value="3" style="text;html=1;align=center;fontSize=10;" vertex="1" parent="1"><mxGeometry x="610" y="232" width="40" height="16" as="geometry" /></mxCell>
        <mxCell id="x4" value="4" style="text;html=1;align=center;fontSize=10;" vertex="1" parent="1"><mxGeometry x="680" y="232" width="40" height="16" as="geometry" /></mxCell>

        <mxCell id="lblRight" value="p=1 の寄与。差分配列なら区間の両端だけ触る → 各 p が O(1)" style="text;html=1;align=center;fontSize=10;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="480" y="262" width="350" height="30" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
