<mxfile host="app.diagrams.net">
  <diagram name="problem-overview" id="problem-overview-1">
    <mxGraphModel dx="980" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="460" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="例: N = 7, X = 2, Y = 5（説明用の小さいインスタンス。公式サンプルではない）" style="text;html=1;align=center;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="160" y="20" width="680" height="24" as="geometry" />
        </mxCell>

        <!-- サイクル / しっぽのラベル -->
        <mxCell id="lbl_cycle" value="サイクル: 2 – 3 – 4 – 5" style="text;html=1;align=center;fontStyle=1;fontSize=12;fontColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="300" y="70" width="200" height="20" as="geometry" />
        </mxCell>
        <mxCell id="lbl_tailL" value="しっぽ" style="text;html=1;align=center;fontSize=11;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="55" y="190" width="60" height="18" as="geometry" />
        </mxCell>
        <mxCell id="lbl_tailR" value="しっぽ" style="text;html=1;align=center;fontSize=11;fontColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="730" y="190" width="60" height="18" as="geometry" />
        </mxCell>

        <!-- 頂点: 1 と 6,7 は直線のしっぽ（青）、2-3-4-5 はサイクル（緑） -->
        <mxCell id="v1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="70" y="240" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="200" y="240" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="320" y="120" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v4" value="4" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="460" y="120" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v5" value="5" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="560" y="240" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v6" value="6" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="690" y="240" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v7" value="7" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="820" y="240" width="50" height="50" as="geometry" /></mxCell>

        <!-- 直線パスのうちサイクルの上側 2-3-4-5 -->
        <mxCell id="c23" style="endArrow=none;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="v2" target="v3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c34" style="endArrow=none;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="v3" target="v4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c45" style="endArrow=none;html=1;strokeColor=#82b366;strokeWidth=2;" edge="1" parent="1" source="v4" target="v5"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 直線の背骨: 1-2, 5-6, 6-7（最短路に使う 1-2, 5-6 は緑で強調） -->
        <mxCell id="l12" style="endArrow=none;html=1;strokeColor=#82b366;strokeWidth=3;" edge="1" parent="1" source="v1" target="v2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="l56" style="endArrow=none;html=1;strokeColor=#82b366;strokeWidth=3;" edge="1" parent="1" source="v5" target="v6"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="l67" style="endArrow=none;html=1;" edge="1" parent="1" source="v6" target="v7"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- ショートカット辺 2-5（背骨の一部・直線 1-2-5-6-7 をつなぐ。赤） -->
        <mxCell id="short" value="ショートカット辺 X–Y (= 2–5)" style="endArrow=none;html=1;strokeColor=#b85450;strokeWidth=2;fontColor=#b85450;fontStyle=1;" edge="1" parent="1" source="v2" target="v5"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 最短路がショートカットを通ることを示す緑の点線（少し下に弧） -->
        <mxCell id="shorthi" style="endArrow=none;html=1;strokeColor=#82b366;strokeWidth=3;curved=1;dashed=1;" edge="1" parent="1" source="v2" target="v5">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="380" y="300" /></Array></mxGeometry>
        </mxCell>

        <!-- 説明ラベル -->
        <mxCell id="exp" value="直線は 1 – 2 – 5 – 6 – 7（背骨）、その途中 2 – 3 – 4 – 5 がサイクル。&#10;頂点 1 → 6 の最短距離は 3（直線 1-2-3-4-5-6 だと 5 だが、1→2→[ショートカット]→5→6 で 3）" style="text;html=1;align=center;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="180" y="360" width="640" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
