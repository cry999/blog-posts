<mxfile host="app.diagrams.net">
  <diagram name="line-count" id="line-count-1">
    <mxGraphModel dx="980" dy="640" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="420" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="直線で距離 d のペアを数える（例: n = 6, d = 2）" style="text;html=1;align=center;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="160" y="20" width="480" height="24" as="geometry" />
        </mxCell>

        <!-- 頂点 1..6 -->
        <mxCell id="v1" value="1" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="80" y="250" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v2" value="2" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="180" y="250" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v3" value="3" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="280" y="250" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v4" value="4" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="380" y="250" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v5" value="5" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="480" y="250" width="50" height="50" as="geometry" /></mxCell>
        <mxCell id="v6" value="6" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="580" y="250" width="50" height="50" as="geometry" /></mxCell>

        <!-- 直線パスの辺 -->
        <mxCell id="e12" style="endArrow=none;html=1;" edge="1" parent="1" source="v1" target="v2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e23" style="endArrow=none;html=1;" edge="1" parent="1" source="v2" target="v3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e34" style="endArrow=none;html=1;" edge="1" parent="1" source="v3" target="v4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e45" style="endArrow=none;html=1;" edge="1" parent="1" source="v4" target="v5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e56" style="endArrow=none;html=1;" edge="1" parent="1" source="v5" target="v6"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- 距離 d=2 のペア (i, i+2) を弧で。i = 1..4 の 4 本（= n - d） -->
        <mxCell id="a13" value="(1,3)" style="endArrow=none;html=1;curved=1;strokeColor=#82b366;strokeWidth=2;fontColor=#82b366;" edge="1" parent="1" source="v1" target="v3"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="205" y="180" /></Array></mxGeometry></mxCell>
        <mxCell id="a24" value="(2,4)" style="endArrow=none;html=1;curved=1;strokeColor=#b85450;strokeWidth=2;fontColor=#b85450;" edge="1" parent="1" source="v2" target="v4"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="305" y="160" /></Array></mxGeometry></mxCell>
        <mxCell id="a35" value="(3,5)" style="endArrow=none;html=1;curved=1;strokeColor=#6c8ebf;strokeWidth=2;fontColor=#6c8ebf;" edge="1" parent="1" source="v3" target="v5"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="405" y="180" /></Array></mxGeometry></mxCell>
        <mxCell id="a46" value="(4,6)" style="endArrow=none;html=1;curved=1;strokeColor=#d79b00;strokeWidth=2;fontColor=#d79b00;" edge="1" parent="1" source="v4" target="v6"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="505" y="160" /></Array></mxGeometry></mxCell>

        <!-- まとめラベル -->
        <mxCell id="note" value="距離 d のペアは (i, i+d) の形だけ。&#10;i は 1 から n − d まで動けるので、ちょうど n − d 個（ここでは 6 − 2 = 4 本）。" style="text;html=1;align=center;fontSize=12;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="120" y="330" width="560" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
