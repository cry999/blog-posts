<mxfile host="app.diagrams.net">
  <diagram name="merge-potentials" id="mp-1">
    <mxGraphModel dx="720" dy="480" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="720" pageHeight="470" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="各ノードのポテンシャル = 根 rx から親への delta を足し上げた値" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="30" y="20" width="670" height="28" as="geometry" />
        </mxCell>
        <mxCell id="rx" value="rx&#10;potential = 0" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="300" y="70" width="110" height="54" as="geometry" />
        </mxCell>
        <mxCell id="x" value="x&#10;potential = delta[x]" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="210" width="120" height="54" as="geometry" />
        </mxCell>
        <mxCell id="ry" value="ry&#10;potential = delta[ry]" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffe6cc;" vertex="1" parent="1">
          <mxGeometry x="470" y="210" width="130" height="54" as="geometry" />
        </mxCell>
        <mxCell id="y" value="y&#10;potential = delta[ry] + delta[y]" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="360" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ex" value="delta[x]" style="html=1;endArrow=classic;" edge="1" parent="1" source="x" target="rx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ery" value="delta[ry]" style="html=1;endArrow=classic;strokeColor=#b85450;strokeWidth=2;fontColor=#b85450;fontStyle=1;" edge="1" parent="1" source="ry" target="rx">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ey" value="delta[y]" style="html=1;endArrow=classic;" edge="1" parent="1" source="y" target="ry">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
