<mxfile host="app.diagrams.net">
  <diagram name="potential" id="potential-1">
    <mxGraphModel dx="640" dy="480" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="delta = 親との差（子 − 親） / ポテンシャル = 根からの累積" style="text;html=1;align=left;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="720" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r" value="根 R&#10;potential=0" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;" vertex="1" parent="1">
          <mxGeometry x="360" y="80" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="a" value="A&#10;potential=+3" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="220" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="b" value="B&#10;potential=-2" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="220" width="100" height="60" as="geometry" />
        </mxCell>
        <mxCell id="c" value="C&#10;potential=+3+4=+7" style="ellipse;whiteSpace=wrap;html=1;" vertex="1" parent="1">
          <mxGeometry x="180" y="360" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ea" value="delta[A]=+3" style="html=1;endArrow=classic;" edge="1" parent="1" source="a" target="r">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="eb" value="delta[B]=-2" style="html=1;endArrow=classic;" edge="1" parent="1" source="b" target="r">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ec" value="delta[C]=+4" style="html=1;endArrow=classic;" edge="1" parent="1" source="c" target="a">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="note" value="diff(B, A) = potential(A) - potential(B) = 3 - (-2) = 5&#10;（A は B より 5 大きい）" style="text;html=1;align=left;verticalAlign=middle;fillColor=#d5e8d4;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="440" y="360" width="320" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
